{
  "name": "User",
  "type": "object",
  "properties": {
    "role": {
      "type": "string",
      "description": "The role of the user in the app",
      "enum": [
        "admin",
        "restaurant_admin",
        "manager",
        "sponsor",
        "staff",
        "user"
      ]
    },
    "branch": {
      "type": "string",
      "description": "Assigned branch key (for manager and staff roles)"
    }
  },
  "required": [
    "role"
  ]
}